<section class="section">
  <div class="section-head">
    <div>
      <div class="section-head-kicker">Saeimas balsojumi</div>
      <h2 class="section-head-title">P&#275;d&#275;jie balsojumi</h2>
    </div>
    <a href="balsojumi.html" class="section-head-link">Visi balsojumi &rarr;</a>
  </div>
  <div class="table-wrap">
    <table class="data-table votes-mini">
      <thead>
        <tr>
          <th>Datums</th>
          <th>Jautājums</th>
          <th>Rezultāts</th>
          <th>Par</th>
          <th>Pret</th>
          <th>Atturas</th>
        </tr>
      </thead>
      <tbody>
        {% for v in recent_votes %}
        <tr>
          <td>{{ v.vote_date|lv_date }}</td>
          <td><a class="vote-link" href="balsojumi.html#vote-{{ v.id }}">{{ v.motif[:80] }}{% if v.motif|length > 80 %}…{% endif %}</a></td>
          <td><span class="badge {% if v.result == 'Pieņemts' %}badge-green{% else %}badge-red{% endif %}">{{ v.result }}</span></td>
          <td><span class="badge badge-green">{{ v.total_par }}</span></td>
          <td><span class="badge badge-red">{{ v.total_pret }}</span></td>
          <td><span class="badge badge-yellow">{{ v.total_atturas }}</span></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>
{% endblock %}

{% block scripts %}
