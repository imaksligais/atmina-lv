{% extends "base.html.j2" %}
{% set active_page = "analizes" %}
{% set assets_prefix = "" %}

{% block title %}Dienas analīze{% endblock %}

{% block content %}
<section class="section">
  <div class="section-header">
    <h1>Dienas analīze</h1>
  </div>

  {% for post in posts %}
  <a href="blog/{{ post.slug }}.html" class="blog-entry" style="display:block; text-decoration:none; color:inherit;">
    <div class="meta">
      <span class="date">{{ post.date }}</span>
      <span class="badge badge-blue">{{ post.type_label }}</span>
    </div>
    <h2>{{ post.title }}</h2>
    <div class="preview">{{ post.preview }}</div>
  </a>
  {% endfor %}

  {% if not posts %}
  <div class="card" style="text-align:center; padding:3rem;">
    <p style="color:var(--text-muted);">Dienas analīzes drīzumā tiks publicētas.</p>
  </div>
  {% endif %}
</section>
{% endblock %}
