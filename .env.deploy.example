# Copy to .env.deploy and fill in. .env.deploy is gitignored.
# Namecheap SSH defaults: port 21098, host = your cPanel server (e.g. server123.web-hosting.com)

DEPLOY_HOST=server123.web-hosting.com
DEPLOY_USER=cpanelusername
DEPLOY_PORT=21098
# For the primary domain, target path is usually ~/public_html
# For an addon domain: ~/public_html/yourdomain.lv  (or whatever cPanel set up)
DEPLOY_PATH=/home/cpanelusername/public_html
