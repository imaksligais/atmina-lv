{# A/B strategy panel — current X_MENTIONS_STRATEGY, 7-run chart, 24h trips.

Args:
  strategy: dict from get_strategy_context() — keys: strategy, runs,
            chart_data, guardrail_trips_24h.
#}
<section id="strategy-panel"
         class="rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 p-6">

  <header class="flex items-baseline justify-between">
    <h2 class="text-base font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
      X_MENTIONS stratēģija
    </h2>
    <span class="text-xs data-mono">
      {% if strategy.strategy == 'search' %}
        <span class="status-info rounded px-2 py-0.5">search</span>
      {% else %}
        <span class="status-neutral rounded px-2 py-0.5">{{ strategy.strategy }}</span>
      {% endif %}
    </span>
  </header>

  <div class="mt-4 text-sarkans">
    {% include "partials/_svg_bars.html.j2" with context %}
  </div>

  {% if strategy.runs %}
  <table class="mt-3 w-full text-xs data-mono">
    <thead class="text-slate-500 dark:text-slate-400">
      <tr>
        <th class="text-left">#log</th>
        <th class="text-right">fetched</th>
        <th class="text-right">stored</th>
        <th class="text-right">err</th>
        <th class="text-right">when</th>
      </tr>
    </thead>
    <tbody>
      {% for run in strategy.runs %}
      <tr class="border-t border-slate-100 dark:border-slate-900">
        <td>{{ run.id }}</td>
        <td class="text-right">{{ run.fetched }}</td>
        <td class="text-right">{{ run.stored }}</td>
        <td class="text-right
                   {% if run.errors > 0 %}text-rose-600 dark:text-rose-400{% endif %}">
          {{ run.errors }}
        </td>
        <td class="text-right text-slate-500 dark:text-slate-400">
          {{ run.timestamp[:16] }}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p class="mt-3 text-sm text-slate-500 dark:text-slate-400">
    Vēl nav reģistrēts neviens mentions_fetch palaišanas ieraksts.
  </p>
  {% endif %}

  <p class="mt-3 text-xs">
    {% if strategy.guardrail_trips_24h > 0 %}
      <span class="status-warning rounded px-2 py-0.5">
        ⚠ guardrail nostrādājis: {{ strategy.guardrail_trips_24h }}× (pēdējās 24h)
      </span>
    {% else %}
      <span class="text-slate-500 dark:text-slate-400">
        guardrail nostrādājis: 0× (pēdējās 24h)
      </span>
    {% endif %}
  </p>
</section>

{# Macro caller pattern: pass chart_data via the strategy context. The
   _svg_bars partial reads `data` directly. #}
{% set data = strategy.chart_data %}
